# ─── Required ────────────────────────────────────────────
DATABASE_URL=postgresql://ceres:ceres@postgres:5432/ceres
REDIS_URL=redis://redis:6379

# ─── LLM Extraction (at least one required for crawling) ─
ANTHROPIC_API_KEY=sk-ant-...
MINIMAX_API_KEY=

# ─── Authentication (optional, leave empty to disable) ───
CERES_AUTH_TOKEN=
VITE_AUTH_TOKEN=

# ─── Proxy (optional) ───────────────────────────────────
PROXY_URL=
PROXY_LIST=

# ─── Captcha Solving (optional) ─────────────────────────
TWOCAPTCHA_API_KEY=

# ─── Storage (optional, for raw HTML archival) ──────────
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
